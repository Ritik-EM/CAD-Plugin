<?xml version="1.0" encoding="UTF-8"?>
<!--
  AtlasCadPlugin (Altium) MSI installer (WiX v3.11 toolset).

  Mirrors CatiaProduct.wxs, but MUCH simpler — Altium has no COM add-in, so there is
  no regasm and no HKLM AddIns key. The MSI just lays down files + a Startup shortcut.

  Build with BuildAltiumMsi.cmd, or by hand on Windows (WiX on PATH, bridge built Release):
    cd installer
    candle -ext WixUtilExtension AltiumProduct.wxs
    light  -ext WixUtilExtension -ext WixUIExtension AltiumProduct.wixobj -out AtlasAltiumPlugin.msi

  What it does:
    1. Copies the bridge (AtlasAltiumBridge.exe + AtlasCadCore.dll + Newtonsoft.Json.dll)
       to C:\Users\Public\AtlasAltium  (world-writable; also the manifest/result exchange dir).
    2. Copies the DelphiScript (AtlasCheckin.pas + AtlasAltium.PrjScr) to
       %LOCALAPPDATA%\Atlas\Altium  (where the Altium Global Project points).
    3. Creates a Startup shortcut "Atlas Altium Watcher" that runs the bridge in watch mode,
       and offers to start the watcher now (ExitDialog checkbox).

  The ONE manual step the MSI can't do (Altium has no script-install hook): the user adds
  the Global Project once in Altium — Preferences > Scripting System > Global Projects > Add
  %LOCALAPPDATA%\Atlas\Altium\AtlasAltium.PrjScr — then binds AtlasCheckin to a button.

  NOTE (per-user pieces in a perMachine MSI): the script + Startup shorttcut are per-user
  components (HKCU keypath); they materialise for the INSTALLING user. On a single-designer
  laptop (the real case) that is the Altium user, so it is fine. Same caveat as the CATIA MSI.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">
  <Product Id="*"
           Name="Atlas CAD Plugin for Altium"
           Language="1033"
           Version="1.0.0.0"
           Manufacturer="Euler Motors"
           UpgradeCode="9D3E5C7A-1B2F-4A8C-9E0D-7F1A2B3C4D5E">

    <Package InstallerVersion="500"
             Compressed="yes"
             InstallScope="perMachine"
             Platform="x64"
             Description="Atlas CAD integration for Altium Designer" />

    <MajorUpgrade
        Schedule="afterInstallInitialize"
        AllowSameVersionUpgrades="yes"
        DowngradeErrorMessage="A newer version of Atlas CAD Plugin for Altium is already installed." />

    <!-- The watcher (the bridge run in watch mode) holds the EXE/DLLs open, so close it
         before an install/upgrade or the files would be locked. -->
    <util:CloseApplication Id="CloseWatcher"
                           Target="AtlasAltiumBridge.exe"
                           CloseMessage="no"
                           RebootPrompt="no"
                           PromptToContinue="yes"
                           Description="The Atlas Altium watcher is running. Close it before installing." />

    <MediaTemplate EmbedCab="yes" />

    <Feature Id="ProductFeature" Title="AtlasAltiumPlugin" Level="1">
      <ComponentGroupRef Id="BridgeComponents" />
      <ComponentGroupRef Id="ScriptComponents" />
      <ComponentGroupRef Id="StartupComponents" />
    </Feature>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <!-- C:\Users\Public\AtlasAltium — PUBLICFOLDER is resolved to %PUBLIC% below, so the
           bridge + the exchange files live in one world-writable place (no admin to read/write). -->
      <Directory Id="PUBLICFOLDER" Name="PUBLIC">
        <Directory Id="INSTALLFOLDER" Name="AtlasAltium" />
      </Directory>

      <!-- %LOCALAPPDATA%\Atlas\Altium — the script (per-user; the Global Project points here). -->
      <Directory Id="LocalAppDataFolder">
        <Directory Id="AtlasLadDir" Name="Atlas">
          <Directory Id="SCRIPTFOLDER" Name="Altium" />
        </Directory>
      </Directory>

      <!-- The per-user Startup folder (built-in WiX directory). -->
      <Directory Id="StartupFolder" />
    </Directory>

    <!-- Resolve PUBLICFOLDER to C:\Users\Public via the %PUBLIC% env var, before
         directories are costed/resolved. -->
    <SetProperty Id="PUBLICFOLDER" Value="[%PUBLIC]" Before="CostFinalize" Sequence="both" />

    <!-- ── Per-machine: the bridge (shared, in C:\Users\Public\AtlasAltium) ── -->
    <ComponentGroup Id="BridgeComponents" Directory="INSTALLFOLDER">
      <Component Id="BridgeExe" Guid="*" Win64="yes">
        <File Id="AtlasAltiumBridgeExe"
              Source="..\AtlasAltium\AtlasAltiumBridge\bin\Release\AtlasAltiumBridge.exe"
              KeyPath="yes" />
      </Component>
      <Component Id="CoreDll" Guid="*" Win64="yes">
        <File Id="AtlasCadCoreDll"
              Source="..\AtlasAltium\AtlasAltiumBridge\bin\Release\AtlasCadCore.dll"
              KeyPath="yes" />
      </Component>
      <Component Id="NewtonsoftJsonDll" Guid="*" Win64="yes">
        <File Id="NewtonsoftJson"
              Source="..\AtlasAltium\AtlasAltiumBridge\bin\Release\Newtonsoft.Json.dll"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ── Per-user: the DelphiScript (%LOCALAPPDATA%\Atlas\Altium) ──
         HKCU keypath so it installs to the installing user's LocalAppData. RemoveFolder
         entries satisfy ICE64 (user-profile dirs must be removable); On="uninstall" only
         removes an empty folder. -->
    <ComponentGroup Id="ScriptComponents">
      <Component Id="ScriptFiles" Directory="SCRIPTFOLDER"
                 Guid="B2C3D4E5-F6A7-4B8C-9D0E-1F2A3B4C5D6E">
        <RegistryValue Root="HKCU"
                       Key="Software\Atlas\AltiumPlugin"
                       Name="ScriptInstalled"
                       Type="integer" Value="1" KeyPath="yes" />
        <File Id="AtlasCheckinPas"  Source="..\AtlasAltium\Script\AtlasCheckin.pas"  Name="AtlasCheckin.pas" />
        <File Id="AtlasAltiumPrjScr" Source="..\AtlasAltium\Script\AtlasAltium.PrjScr" Name="AtlasAltium.PrjScr" />
        <RemoveFolder Id="RemoveScriptFolder" Directory="SCRIPTFOLDER" On="uninstall" />
        <RemoveFolder Id="RemoveAtlasLadDir"  Directory="AtlasLadDir"  On="uninstall" />
      </Component>
    </ComponentGroup>

    <!-- ── Per-user: the watcher autostart shortcut (Startup folder) ── -->
    <ComponentGroup Id="StartupComponents">
      <Component Id="WatcherShortcut" Directory="StartupFolder"
                 Guid="C3D4E5F6-A7B8-4C9D-0E1F-2A3B4C5D6E7F">
        <RegistryValue Root="HKCU"
                       Key="Software\Atlas\AltiumPlugin"
                       Name="WatcherShortcut"
                       Type="integer" Value="1" KeyPath="yes" />
        <Shortcut Id="AtlasAltiumWatcherLnk"
                  Name="Atlas Altium Watcher"
                  Description="Atlas Altium check-in watcher"
                  Target="[INSTALLFOLDER]AtlasAltiumBridge.exe"
                  Arguments="--watch"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveStartupShortcut" Directory="StartupFolder" On="uninstall" />
      </Component>
    </ComponentGroup>

    <!-- Offer to start the watcher right after an interactive install (otherwise it
         starts at the next login via the Startup shortcut). asyncNoWait = fire-and-forget. -->
    <CustomAction Id="LaunchWatcher"
                  Directory="INSTALLFOLDER"
                  ExeCommand="&quot;[INSTALLFOLDER]AtlasAltiumBridge.exe&quot; --watch"
                  Return="asyncNoWait" />

    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Start the Atlas check-in watcher now" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />

    <UI>
      <UIRef Id="WixUI_Minimal" />
      <Publish Dialog="ExitDialog" Control="Finish" Event="DoAction" Value="LaunchWatcher">
        WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed
      </Publish>
    </UI>

    <!-- Real license text instead of WiX's built-in lorem-ipsum placeholder. -->
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />
  </Product>
</Wix>
